{
  "name": "contentai-server",
  "version": "1.0.0",
  "description": "ContentAI backend — Express + JWT + Google OAuth",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "generate:secrets": "node -e \"const c=require('crypto');console.log('JWT_SECRET='+c.randomBytes(64).toString('hex'));console.log('JWT_REFRESH_SECRET='+c.randomBytes(64).toString('hex'));console.log('COOKIE_SECRET='+c.randomBytes(32).toString('hex'));\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lowdb": "^7.0.1",
    "mammoth": "^1.12.0",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
